rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // App configuration documents - public read access
    match /app/{document} {
      allow read: if true;  // Public read - anyone can read app config (landingPage, onboarding, etc.)
      allow write: if request.auth != null;  // Only authenticated users can write
    }
    
    // Deletion requests - allow public write (for web form), but only admins can read
    match /deletion_requests/{requestId} {
      allow create: if true;  // Anyone can create a deletion request
      allow read, update, delete: if false;  // Only admins (via Functions) can read/update
    }
    
    // Feedback collection - authenticated users can submit feedback
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;  // Authenticated users can submit feedback
      allow read, update, delete: if false;  // Only admins can read/manage feedback
    }
    
    // Content reports collection - users can report offensive AI-generated content
    match /content_reports/{reportId} {
      allow create: if true;  // Anyone can create a content report (including anonymous users)
      allow read, update, delete: if false;  // Only admins can read/manage reports
    }
    
    // User data - users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Jobs subcollection - user can read their own video generation jobs
      match /jobs/{jobId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only backend (Cloud Functions) can write jobs
      }
      
      // Subscriptions subcollection - user can read their own subscriptions
      match /subscriptions/{subscriptionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only backend can write subscriptions
      }
      
      // Purchases subcollection - user can read their own purchase history
      match /purchases/{purchaseToken} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only backend can write purchase history
      }
    }
    
    // Models collection - public read access for available AI models
    match /models/{modelId} {
      allow read: if true;
      allow write: if false; // Only admins can modify models
    }
    
    // Video features collection - public read access for available AI models
    match /video_features/{modelId} {
      allow read: if true;
      allow write: if false; // Only admins can modify models
    }
    
    // Video effects collection - public read access for video effects
    match /video_effects/{effectId} {
      allow read: if true;
      allow write: if false; // Only admins can modify effects
    }
  }
}
